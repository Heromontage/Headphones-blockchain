# Database configuration (existing)
MYSQL_HOST=localhost
MYSQL_USER=aether_user
MYSQL_PASSWORD=aether_password
MYSQL_DATABASE=aether_db

# Rewards program configuration
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=your_deployed_contract_address_here
